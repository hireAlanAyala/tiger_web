{
  "private": true,
  "scripts": {
    "codegen": "./zig/zig build codegen",
    "scan": "./zig/zig build scan -- ts/handlers/ --manifest=generated/manifest.json",
    "adapter": "tsx adapters/typescript.ts generated/manifest.json generated/dispatch.generated.ts",
    "build": "npm run codegen && npm run scan && npm run adapter",
    "sidecar": "tsx generated/dispatch.generated.ts /tmp/tiger-web.sock",
    "server": "./zig/zig build run -- --sidecar=/tmp/tiger-web.sock",
    "dev": "npm run build && concurrently 'npm run sidecar' 'sleep 1 && npm run server'",
    "test:serde": "tsx generated/serde_test.generated.ts",
    "test:adapter": "./zig/zig build test-adapter",
    "test:zig": "./zig/zig build unit-test"
  },
  "devDependencies": {
    "tsx": "^4",
    "concurrently": "^9",
    "typescript": "^5"
  }
}
