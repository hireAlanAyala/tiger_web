#!/bin/sh
set -e

# Internal CLI — runs inside the Docker container.
# Not for direct user invocation. Called by `focus` (the host CLI).

FRAMEWORK="/opt/focus"
PROJECT="/app"
SOCK="/tmp/focus.sock"

# Copy SDK types into the project so tsconfig paths resolve.
sync_types() {
  mkdir -p "$PROJECT/.focus"
  cp "$FRAMEWORK/generated/types.generated.ts" "$PROJECT/.focus/"
  cp "$FRAMEWORK/generated/serde.ts" "$PROJECT/.focus/"
  cp "$FRAMEWORK/generated/routing.ts" "$PROJECT/.focus/"
}


case "$1" in
  build)
    sync_types

    # Scan handler annotations → manifest + operations + routes.
    # The scanner generates routes from .zig handler files only.
    # TS-only projects get an empty route table → all requests go
    # through the sidecar's 2-RT route_prefetch path.
    cd "$FRAMEWORK"
    ./zig/zig build scan -- \
      "$PROJECT/handlers/" \
      --manifest="$PROJECT/.focus/manifest.json" \
      --registry=generated/operations.json \
      --operations-zig=generated/operations.generated.zig \
      --routes-zig=generated/routes.generated.zig

    # Generate TypeScript dispatch + operations.ts into the project's .focus/
    # so handler imports resolve relative to the project, not framework.
    PATH="$PROJECT/node_modules/.bin:$PATH" \
      tsx adapters/typescript.ts \
        "$PROJECT/.focus/manifest.json" \
        "$PROJECT/.focus/handlers.generated.ts" \
        "$FRAMEWORK/generated/operations.json" \
        "$PROJECT/.focus/operations.ts"

    # Symlink so the sidecar runtime finds handlers.generated.ts at
    # its expected import path (../generated/handlers.generated.ts).
    ln -sf "$PROJECT/.focus/handlers.generated.ts" generated/handlers.generated.ts

    # Replace hand-written Operation type with re-export from generated.
    node -e "
      const path = '$PROJECT/.focus/types.generated.ts';
      let src = require('fs').readFileSync(path, 'utf-8');
      src = src.replace(/export type Operation =[\s\S]*?;/,
        '// Operation type generated from operations.json.\nexport type { Operation } from \"./operations.ts\";');
      require('fs').writeFileSync(path, src);
    "

    echo "Build complete."
    ;;

  dev)
    focus-internal build

    # Build the sidecar-enabled server binary.
    # Zig's content-hash cache makes this ~50ms when nothing changed.
    cd "$FRAMEWORK"
    ./zig/zig build -Dsidecar=true

    # Run user schema if present (creates tables on first startup).
    if [ -f "$PROJECT/schema.sql" ]; then
      sqlite3 "$PROJECT/tiger_web.db" < "$PROJECT/schema.sql"
    fi

    # Clean stale state.
    rm -f "$SOCK"
    rm -f /dev/shm/tiger-*

    # Start server in background.
    "$FRAMEWORK/zig-out/bin/tiger-web" start \
      --port=3000 \
      --sidecar="$SOCK" \
      --db="$PROJECT/tiger_web.db" &
    SERVER_PID=$!
    SHM_NAME="tiger-$SERVER_PID"
    SIDECAR_PID=""

    cleanup() {
      [ -n "$SIDECAR_PID" ] && kill "$SIDECAR_PID" 2>/dev/null || true
      kill "$SERVER_PID" 2>/dev/null || true
      rm -f "$SOCK" "/dev/shm/$SHM_NAME" "/dev/shm/${SHM_NAME}-workers"
    }
    trap cleanup EXIT INT TERM

    # Wait for SHM.
    for i in $(seq 1 50); do
      [ -f "/dev/shm/$SHM_NAME" ] && break
      sleep 0.1
    done
    if [ ! -f "/dev/shm/$SHM_NAME" ]; then
      echo "error: server did not start." >&2
      exit 1
    fi

    # Start sidecar.
    start_sidecar() {
      cd "$PROJECT"
      npx tsx "$FRAMEWORK/adapters/call_runtime_shm.ts" "$SHM_NAME" "$SOCK" &
      SIDECAR_PID=$!
    }

    restart_sidecar() {
      echo "Rebuilding..."
      if focus-internal build 2>&1; then
        echo "Restarting sidecar..."
        [ -n "$SIDECAR_PID" ] && kill "$SIDECAR_PID" 2>/dev/null || true
        # The bus force-closes stuck connections after 500ms (50 ticks).
        # Wait for the slot to free up before starting the new sidecar.
        sleep 1
        start_sidecar
      else
        echo "Build failed — sidecar not restarted."
      fi
    }

    start_sidecar

    echo ""
    echo "  Tiger Web running on http://localhost:3000"
    echo "  Watching handlers/ for changes..."
    echo ""

    # File watcher — poll for handler changes every second.
    # inotifywait doesn't work across Docker volume mounts (host
    # changes don't generate inotify events inside the container).
    # Polling is simple, reliable, and ~1s latency is fine for dev.
    HANDLER_DIR="$PROJECT/handlers"
    LAST_HASH=""
    while true; do
      HASH=$(find "$HANDLER_DIR" -name '*.ts' -exec stat -c '%Y %n' {} \; 2>/dev/null | sort)
      if [ -n "$LAST_HASH" ] && [ "$HASH" != "$LAST_HASH" ]; then
        restart_sidecar
      fi
      LAST_HASH="$HASH"
      sleep 1
    done
    ;;

  *)
    echo "Usage: focus-internal <build|dev>" >&2
    exit 1
    ;;
esac
