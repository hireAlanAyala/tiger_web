#!/bin/sh
set -e

FRAMEWORK_ROOT="$(cd "$(dirname "$0")" && pwd)"
EXAMPLE_DIR="$(pwd)"
EXAMPLE_REL="${EXAMPLE_DIR#"$FRAMEWORK_ROOT"/}"
SOCK="/tmp/tiger-web.sock"

case "$1" in
  build)
    cd "$FRAMEWORK_ROOT"
    ./zig/zig build scan -- "$EXAMPLE_REL/handlers/" --manifest=generated/manifest.json
    PATH="$EXAMPLE_DIR/node_modules/.bin:$PATH" tsx adapters/typescript.ts generated/manifest.json generated/handlers.generated.ts
    ;;
  dev)
    "$0" build
    cd "$EXAMPLE_DIR"
    # Server starts first (listens on unix socket), sidecar connects.
    # call_runtime.ts is the CALL/RESULT runtime (replaces dispatch.generated.ts).
    npx concurrently \
      "cd $FRAMEWORK_ROOT && ./zig/zig build run -- --sidecar=$SOCK" \
      "sleep 2 && tsx $FRAMEWORK_ROOT/adapters/call_runtime.ts $SOCK"
    ;;
  *)
    echo "Usage: tiger-web <build|dev>"
    exit 1
    ;;
esac
