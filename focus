#!/bin/sh
set -e

# Tiger Web CLI — single entry point for the framework.
#
# Install: curl -sSf https://focus.dev/install.sh | sh
# Usage:   focus new myapp && cd myapp && focus dev

TIGER_VERSION="0.1.0"
TIGER_IMAGE="focus:${TIGER_VERSION}"

# --- Locate framework root ---
# If run from a git clone, use that. Otherwise, the Docker image has
# the framework at /opt/focus.
if [ -f "$(cd "$(dirname "$0")" && pwd)/build.zig" ]; then
  FRAMEWORK_ROOT="$(cd "$(dirname "$0")" && pwd)"
else
  FRAMEWORK_ROOT=""
fi

# --- Helpers ---
check_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "error: docker not found. Install Docker: https://docs.docker.com/get-docker/" >&2
    exit 1
  fi
  if ! docker info >/dev/null 2>&1; then
    echo "error: docker daemon not running. Start Docker Desktop or: sudo systemctl start docker" >&2
    exit 1
  fi
}

ensure_image() {
  if ! docker image inspect "$TIGER_IMAGE" >/dev/null 2>&1; then
    if [ -n "$FRAMEWORK_ROOT" ]; then
      echo "Building focus Docker image (first time only)..."
      docker build -t "$TIGER_IMAGE" "$FRAMEWORK_ROOT"
    else
      echo "error: focus Docker image not found. Build from source:" >&2
      echo "  git clone https://github.com/focus/focus && cd focus" >&2
      echo "  docker build -t $TIGER_IMAGE ." >&2
      exit 1
    fi
  fi
}

run_in_container() {
  docker run --rm -it \
    -v "$(pwd):/app" \
    -w /app \
    --security-opt seccomp=unconfined \
    "$@" \
    "$TIGER_IMAGE"
}

case "$1" in
  # --- focus new <name> ---
  new)
    PROJECT_NAME="$2"
    if [ -z "$PROJECT_NAME" ]; then
      echo "Usage: focus new <project-name>" >&2
      exit 1
    fi
    if [ -e "$PROJECT_NAME" ]; then
      echo "error: '$PROJECT_NAME' already exists." >&2
      exit 1
    fi

    mkdir -p "$PROJECT_NAME/handlers"

    cat > "$PROJECT_NAME/package.json" << 'EOF'
{
  "private": true,
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "focus dev",
    "build": "focus build"
  },
  "devDependencies": {
    "tsx": "^4",
    "typescript": "^5"
  }
}
EOF

    cat > "$PROJECT_NAME/tsconfig.json" << 'EOF'
{
  "compilerOptions": {
    "strict": true,
    "noUnusedParameters": false,
    "target": "es2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "paths": { "tiger-web": [".focus/types.generated.ts"] },
    "baseUrl": "."
  },
  "include": ["handlers/**/*.ts"]
}
EOF

    # Schema — runs on first startup (before server).
    cat > "$PROJECT_NAME/schema.sql" << 'SQL'
CREATE TABLE IF NOT EXISTS items (
  id TEXT PRIMARY KEY,
  name TEXT NOT NULL
);
SQL

    cat > "$PROJECT_NAME/.gitignore" << 'GI'
node_modules/
.focus/
tiger_web.db
tiger_web.wal
GI

    cat > "$PROJECT_NAME/handlers/list_items.ts" << 'HANDLER'
import type { RouteRequest, RouteResult, PrefetchMessage, PrefetchDb, HandleContext, RenderContext } from "tiger-web";
import { esc } from "tiger-web";

// [route] .list_items
// match GET /
export function route(_req: RouteRequest): RouteResult | null {
  return { operation: "list_items", id: "0".repeat(32) };
}

// [prefetch] .list_items
export async function prefetch(_msg: PrefetchMessage, db: PrefetchDb) {
  const items = await db.queryAll("SELECT id, name FROM items ORDER BY id LIMIT ?1", 50);
  return { items };
}

// [handle] .list_items
export function handle(_ctx: HandleContext): string {
  return "ok";
}

// [render] .list_items
export function render(ctx: RenderContext): string {
  const items = ctx.prefetched.items as any[] | null;
  if (!items || items.length === 0) return "<p>No items yet. POST / to create one.</p>";
  return "<ul>" + items.map((i: any) => `<li>${esc(i.name)}</li>`).join("") + "</ul>";
}
HANDLER

    cat > "$PROJECT_NAME/handlers/create_item.ts" << 'HANDLER'
import type { RouteRequest, RouteResult, HandleContext, WriteDb, RenderContext } from "tiger-web";

// [route] .create_item
// match POST /
export function route(req: RouteRequest): RouteResult | null {
  const parsed = JSON.parse(req.body || "{}");
  const name = String(parsed.name || "");
  if (!name) return null;
  const id = String(parsed.id || "0".repeat(32));
  return { operation: "create_item", id, body: { id, name } };
}

// [prefetch] .create_item
export async function prefetch() { return {}; }

// [handle] .create_item
export function handle(ctx: HandleContext, db: WriteDb): string {
  db.execute("INSERT OR IGNORE INTO items (id, name) VALUES (?1, ?2)", ctx.body.id, ctx.body.name);
  return "ok";
}

// [render] .create_item
export function render(_ctx: RenderContext): string {
  return "<p>Created.</p>";
}
HANDLER

    echo ""
    echo "  Created $PROJECT_NAME/"
    echo ""
    echo "  Next steps:"
    echo "    cd $PROJECT_NAME"
    echo "    focus dev"
    echo ""
    echo "  Then visit http://localhost:3000"
    echo ""
    ;;

  # --- focus build ---
  build)
    check_docker
    ensure_image
    run_in_container \
      sh -c "focus-internal build"
    ;;

  # --- focus dev ---
  dev)
    check_docker
    ensure_image
    echo ""
    echo "  Tiger Web starting..."
    echo ""
    run_in_container \
      -p 3000:3000 \
      sh -c "npm install --silent 2>/dev/null && focus-internal dev"
    ;;

  # --- focus load ---
  # Run a load test against a running server.
  load)
    check_docker
    ensure_image
    shift
    run_in_container \
      --network host \
      sh -c "cd /opt/focus && ./zig/zig build load -Doptimize=ReleaseSafe -- $*"
    ;;

  # --- focus replay ---
  # Inspect or replay the WAL file.
  replay)
    check_docker
    ensure_image
    shift
    run_in_container \
      sh -c "/opt/focus/zig-out/bin/tiger-replay $*"
    ;;

  version)
    echo "focus $TIGER_VERSION"
    ;;

  # --- focus docs ---
  docs)
    cat << 'DOCS'
FOCUS — TypeScript web framework backed by Zig

  focus new <name>      Create a new project
  focus dev             Build + run with auto-reload
  focus build           Scan handlers + generate dispatch
  focus docs            This page
  focus version         Print version

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

HANDLERS

  Every operation is a TypeScript file in handlers/ with annotated exports.
  Four phases run in order: route → prefetch → handle → render.

  // [route] .create_item
  // match POST /items
  export function route(req: RouteRequest): RouteResult | null

  // [prefetch] .create_item
  export async function prefetch(msg: PrefetchMessage, db: PrefetchDb)

  // [handle] .create_item
  export function handle(ctx: HandleContext, db: WriteDb): string

  // [render] .create_item
  export function render(ctx: RenderContext): string

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ANNOTATIONS

  // [route] .operation        Declare a route phase
  // match GET /path/:id       HTTP method + URL pattern
  // query param_name          Extract ?param from query string (max 4)

  // [prefetch] .operation     Declare a prefetch phase (read-only SQL)
  // [handle] .operation       Declare a handle phase (write SQL)
  // [render] .operation       Declare a render phase (HTML output)

  // [worker] .operation       Declare an async worker
  // id field_name             Which result field is the entity ID

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

PHASE RULES

  Phase        DB Access        Side Effects     Async
  ─────        ─────────        ────────────     ─────
  [route]      none             parse only       no
  [prefetch]   db.query()       FORBIDDEN        no
  [handle]     db.execute()     FORBIDDEN        no
  [render]     none             FORBIDDEN        no
  [worker]     db.query()       ALLOWED          yes

  Side effects (HTTP calls, file I/O, timers, randomness) are ONLY
  allowed in [worker] phases. Every other phase is pure computation
  over its inputs. This is not a style choice — the framework replays
  prefetch and handle during crash recovery. Side effects in these
  phases means recovery produces different results than the original.

  Workers are for: payment processing, email, image processing,
  external API calls — anything with latency or side effects.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

TYPES (import from "tiger-web")

  RouteRequest    { method, path, body, params }
  RouteResult     { operation, id, body? }  — return null to reject
  PrefetchMessage { operation, id, body }
  PrefetchDb      { query(sql, ...params), queryAll(sql, ...params) }
  HandleContext   { operation, id, prefetched, body, worker_failed? }
  WriteDb         { execute(sql, ...params) }
  RenderContext   { operation, id, status, prefetched, body, is_sse }

  Utilities:
    esc(s)          HTML-escape a string
    price(cents)    Format cents as "$X.XX"
    shortId(id)     First 8 chars of UUID
    assert(cond)    Throw on false
    unreachable(x)  Exhaustiveness check for switch

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

WORKERS

  Workers run async code with side effects. They dispatch from
  [handle] and complete through their own [handle] + [render].

  // [worker] .charge_payment
  // id order_id
  export async function charge_payment(ctx, db) {
    const order = await db.query("SELECT ...", ctx.id);
    await stripe.charges.create({ amount: order.total });
    return { order_id: ctx.id, paid: true };
  }

  // [handle] .charge_payment
  export function handle(ctx: HandleContext, db: WriteDb): string {
    if (ctx.worker_failed) return "failed";
    db.execute("UPDATE orders SET status='paid' WHERE id=?1", ctx.id);
    return "ok";
  }

  Dispatch from another handler:
    worker.charge_payment(order_id, { amount: 1000 });

  Limits:
    Max in-flight:    16 concurrent workers
    Deadline:         30 seconds
    Max args:         4096 bytes
    Max result:       4096 bytes
    Max dispatches:   4 per handle call

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

THE FOCUS BIBLE

  1. Your handler is four pure functions.
     route decides what to do. prefetch reads data. handle writes
     data. render produces HTML. Each function sees only what the
     previous one produced. No globals. No shared state. No surprises.

  2. Side effects go in workers. Everything else is math.
     If it talks to the network, writes to a file, or checks the
     clock — it's a worker. The framework needs to be able to replay
     your handle phase during crash recovery. It can't replay a
     Stripe charge.

  3. Reads before writes. Always.
     Prefetch runs before handle. You declare what data you need,
     the framework fetches it, then you make a decision. You never
     read during a write. This is what makes the system fast — reads
     run concurrently, writes run serially.

  4. Every write is a SQL statement. No exceptions.
     db.execute() queues a SQL mutation. The framework commits all
     mutations atomically after handle returns. If handle throws,
     nothing is written. You can't half-commit.

  5. HTML is the response. Not JSON. Not a redirect.
     render() returns an HTML string. The server sends it directly.
     No template engine, no JSX compilation, no virtual DOM. Just
     string concatenation. Use esc() for user data.

  6. The scanner is the compiler.
     focus build scans your annotations and validates them before
     the server starts. Missing phases, wrong status values, bad
     route patterns — all caught at build time, not runtime.

  7. One file per operation. No shared handler state.
     create_item.ts has route + prefetch + handle + render for the
     create_item operation. Nothing else. No base classes. No
     middleware. No interceptors. Find the operation, read the file.

  8. Convention over configuration.
     No config files. No middleware registration. No route tables.
     Comment annotations declare intent. The framework does the rest.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

LIMITS

  Max HTTP body:          4096 bytes
  Max connections:        128 concurrent
  Max query params:       4 per route
  Max SQL frame:          256 KB
  Sidecar timeout:        5 seconds
  Worker deadline:        30 seconds
  Worker slots:           16 concurrent

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

TOOLS

  focus load --port=3000 --connections=128 --requests=100000
    Load test a running server. Measures throughput and latency
    per operation. Use --seed=N for reproducible runs.

  focus replay verify tiger_web.wal
    Validate WAL checksums and hash chain integrity.

  focus replay inspect tiger_web.wal
    Print human-readable WAL entry summaries.

  focus replay replay tiger_web.wal backup.db
    Replay all WAL writes against a database.

DOCS
    ;;

  *)
    echo "Focus $TIGER_VERSION"
    echo ""
    echo "Usage:"
    echo "  focus new <name>    Create a new project"
    echo "  focus dev           Build + run with auto-reload"
    echo "  focus build         Scan handlers + generate dispatch"
    echo "  focus load          Run load test against running server"
    echo "  focus replay        Inspect or replay the WAL"
    echo "  focus docs          Framework reference"
    echo "  focus version       Print version"
    exit 1
    ;;
esac
