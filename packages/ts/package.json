{
  "name": "focus",
  "version": "0.1.0",
  "description": "Focus framework TypeScript runtime — protocol client, types, codegen, serde",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "focus-sidecar": "src/bin/focus-sidecar.ts",
    "focus-codegen": "src/bin/focus-codegen.ts"
