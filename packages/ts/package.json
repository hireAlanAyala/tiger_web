    "build:native": "../../zig/zig cc -shared -o native/shm.node native/shm.c -I/usr/include/node -lrt -lz -fPIC"
  },
  "dependencies": {
    "tsx": "^4"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5"
  }
